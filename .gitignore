cat > .gitignore << 'EOF'
# Node / Next
node_modules/
.next/
out/
dist/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.env*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Rust / Tauri
**/target/
**/*.rs.bk

# Tauri bundles (optional - usually do NOT commit)
**/src-tauri/target/
EOF